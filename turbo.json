{
    "$schema":"https://turbo.build/schema.json",
    "ui":"tui", 
    "tasks":{
        "build": {
            "dependsOn": ["^build"], 
            "outputs": ["dist/**", "next/**", "!dist/**/node_modules/**", "!next/**/node_modules/**", "!.next/cache/**"] 
        },
        "dev":{
            "cache": false, 
            "persistent": true 
        },
        "prettier":{
            "cache": false,
            "persistent": true
        },
        "lint":{
            "cache": false,
            "persistent": true
        }
    }
}